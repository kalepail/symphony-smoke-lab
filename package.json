{
  "name": "markdown-editor",
  "private": true,
  "version": "0.1.0",
  "description": "Forward-looking Markdown Editor built on Vite, Vitest, and OXC linting.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "oxlint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run test && npm run build",
    "smoke:validate": "sh scripts/validate-smoke-repo.sh"
  },
  "devDependencies": {
    "oxlint": "^1.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
